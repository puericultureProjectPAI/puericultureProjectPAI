# ==============================================================================
# PROJET PUÉRICULTURE - TEMPLATE DES VARIABLES D'ENVIRONNEMENT
# Instructions : Copier ce fichier vers '.env' et remplir les valeurs.
# NE JAMAIS COMMITER LE FICHIER '.env' FINAL.
# ==============================================================================

# --- CONFIGURATION DATABASE (SUPABASE) ---
# En dev local : utiliser les valeurs par défaut de 'supabase start'
# En prod : utiliser les credentials du dashboard Supabase
DATABASE_URL=jdbc:postgresql://localhost:5432/postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=your_local_supabase_password

# --- CONFIGURATION IA ---
# En dev : utiliser la clé 'ollama' (ignorée par le serveur local)
# En prod : utiliser votre clé OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- SÉCURITÉ ---
# Clé secrète pour la signature des jetons JJWT (min. 32 caractères pour HS256)
JWT_SECRET_KEY=a_very_long_and_random_secret_string_for_dev_only

# --- SERVEUR ---
SERVER_PORT=8080