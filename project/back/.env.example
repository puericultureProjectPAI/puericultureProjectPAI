# ==============================================================================
# PROJET PUÉRICULTURE - TEMPLATE DES VARIABLES D'ENVIRONNEMENT
# Instructions : Copier ce fichier vers '.env'. Les valeurs par défaut
# sont pré-configurées pour un environnement local Supabase standard.
# NE JAMAIS COMMITER LE FICHIER '.env' FINAL.
# ==============================================================================

# --- CONFIGURATION DATABASE (SUPABASE LOCAL) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:54322/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- SÉCURITÉ SUPABASE ---
# Service key is obtained in the supabase status (Authentication Keys Secret)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your_service_role_key_here

# --- STORAGE CLOUDINARY ---
# Cloudinary (Leave blank locally to avoid crashes and activate the Mock)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- INTELLIGENCE ARTIFICIELLE ---
# Clé requise pour le test local avec OpenRouter/Ollama
OPENAI_API_KEY=your_local_or_test_key_here

# --- SERVEUR ---
SERVER_PORT=8080