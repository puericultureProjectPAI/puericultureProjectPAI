# ==============================================================================
# PROJET PUÉRICULTURE - TEMPLATE DES VARIABLES D'ENVIRONNEMENT
# Instructions : Copier ce fichier vers '.env'. Les valeurs par défaut
# sont pré-configurées pour un environnement local Supabase standard.
# NE JAMAIS COMMITER LE FICHIER '.env' FINAL.
# ==============================================================================

# --- CONFIGURATION DATABASE (SUPABASE LOCAL) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- SÉCURITÉ ---
# Clé secrète pour la signature des jetons JJWT (min. 32 caractères pour HS256)
# Cette clé est la clé de base crée par Supabase lors de l'initialisation du projet local.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# Supabase URL (APIs Project URL)
SUPABASE_URL= http://127.0.0.1:54321 
# Supabase Authentication Key (Authentication Keys Secret)
SUPABASE_SERVICE_KEY=a_very_long_and_random_secret_string_for_dev_only


# --- SERVEUR ---
SERVER_PORT=8080