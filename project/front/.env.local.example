# ==============================================================================
# PROJET PUÉRICULTURE - FRONTEND
# Fichier d'exemple pour les variables d'environnement locales
# Instructions : Copier ce fichier vers '.env.local'
# ==============================================================================

# L'URL de ton backend Spring Boot en local
VITE_API_URL=http://127.0.0.1:8080

# La clé anonyme (Publishable) par défaut de Supabase local.
# ATTENTION: Il s'agit bien de la clé "Publishable" et NON de la clé "Secret".
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# L'URL du projet Supabase en local (API Gateway)
VITE_SUPABASE_URL=http://127.0.0.1:54321

# ==============================================================================
# CLOUDINARY - image management
# ==============================================================================
# Leave these variables empty locally to force the use of the Mock server (localhost:8081).
# Fill them in to send the images to Cloudinary’s real servers.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=